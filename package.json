{
  "name": "even-agent",
  "version": "1.0.3",
  "description": "Agente de sincronizacion Even - Soft Restaurant",
  "main": "src/main.js",
  "scripts": {
    "start": "node start.js",
    "build": "electron-builder --win"
  },
  "author": "Even",
  "license": "UNLICENSED",
  "dependencies": {
    "electron-store": "^8.1.0",
    "mssql": "^10.0.4",
    "pngjs": "^7.0.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^27.3.11",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.even.agent",
    "productName": "Even Agent",
    "icon": "assets/icon-white.ico",
    "win": {
      "target": "portable",
      "signAndEditExecutable": true,
      "certificateFile": "certs/even-codesign.pfx",
      "certificatePassword": "even2026",
      "artifactName": "Even Agent.${ext}",
      "icon": "assets/icon-white.ico"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "config.example.json"
    ],
    "extraResources": [
      {
        "from": "config.example.json",
        "to": "config.example.json"
      }
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
